/*
./a.out hello world!
argc = 3
argv[0] = ./a.out
argv[1] = hello
argv[2] = world!
*/

extern func print_string(fd: u64, s: ptr<imm u8>); /* from ASM runtime lib to print raw string */

func main(argc: i64, argv: ptr<ptr<imm u8>>) returns (rc: u8) {
  print "argc = ", argc, "\n";
  for (mut i := 0; i < argc; i = i + 1) {
    print "argv[", i, "] = ";
    print_string(1, argv[i]);
    print "\n";
  }
  return 0;
}
