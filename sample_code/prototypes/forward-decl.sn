func is_even(n: i32) returns (res: bool);

func is_odd(n: i32) returns (res: bool) {
  if (n == 0) { return false; }
  return is_even(n - 1);
}

func is_even(n: i32) returns (res: bool) {
  if (n == 0) { return true; }
  return is_odd(n - 1);
}

b := 4;
if (is_even(b)) {
  print b, " is even\n";
} else {
  print b, " is odd\n";
}
