/*
Expected Output:
  1
  2
  Fizz
  4
  Buzz
  Fizz
  7
  8
  Fizz
  Buzz
  11
  Fizz
  13
  14
  FizzBuzz
*/

func main() {
  n : i32 = 15;
  mut i : i32 = 1;
  while (i <= n) {
    if (i % 15 == 0) {
      print "FizzBuzz\n";
    } else if (i % 3 == 0) {
      print "Fizz\n";
    } else if (i % 5 == 0) {
      print "Buzz\n";
    } else {
      print i, "\n";
    }
    i = i + 1;
  }
}
